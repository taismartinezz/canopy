{
  "manifest_version": 3,
  "name": "Save to Canopy",
  "version": "1.0.0",
  "description": "One-click save of the current page (title, URL, DOI) into your Canopy Lab Library.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Canopy"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
